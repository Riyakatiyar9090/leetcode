class Solution {
public:
    bool isPalindrome(string s) {
        string p="";
        if(s.length()==1){
            return true;
        }
       for(int i=0;i<s.length();i++){
        if(isalnum(s[i])){
            p+=tolower(s[i]);
        }
       }
       int n=p.length();
       for(int i=0;i<n/2;i++){
        if(p[i]!=p[n-i-1]){
            return false;
        }
       }
       return true;
    }
};
