class Solution {
public:
    int firstUniqChar(string s) {
        map<int,int> mp;
        for(auto ch: s){
            mp[ch]++;
        }
       for(int i=0;i<s.length();i++){
        if(mp[s[i]]==1){
            return i;
        }
       }
       return -1;
    }
};

**********************************************OR********************************************
class Solution {
public:
    int firstUniqChar(string s) {
        vector<int>letters(26);
        int n = s.length();

        for(int i=0;i<n;i++){
            char ch = s[i];
            letters[ch-'a']++;
        }

        for(int i=0;i<n;i++){
            char ch = s[i];
            if(letters[ch-'a'] ==1){
                return i;
            }
        }
        return -1;
    }
};
