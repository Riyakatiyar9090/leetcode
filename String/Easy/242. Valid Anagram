class Solution {
public:
    bool isAnagram(string s, string t) {
        vector<int> v(26,0);
        if(s.length()!=t.length()){
            return false;
        }
        else{
        for(auto c:t){
            v[c-'a']++;
        }
        for(auto c: s){
            if(v[c-'a']==0){
                return false;
            }
            v[c-'a']--;
        }
        }
        return true;

    }
};
